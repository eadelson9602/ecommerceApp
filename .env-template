# =============================================================================
# E-commerce Backend – Plantilla de variables de entorno
# =============================================================================
# Copiar a .env y rellenar valores. No versionar .env (está en .gitignore).
#
# PRODUCCIÓN: No usar valores por defecto. JWT_SECRET e API keys deben provenir
# de variables inyectadas (CI/CD, Kubernetes secrets, Vault, etc.). En prod no
# definir JWT_SECRET ni *_API_KEY con valores de desarrollo.
#
# CARGA AUTOMÁTICA: Al arrancar cada servicio (products-service o inventory-service),
# la aplicación busca .env en el directorio de trabajo o en directorios padre (hasta
# la raíz del proyecto) y carga estas variables. No hace falta ejecutar "source .env".
# Las variables ya definidas en el sistema (export, Docker, etc.) tienen prioridad.
#
# Un solo .env en la raíz puede definir variables de ambos servicios (prefijos
# PRODUCTS_* e INVENTORY_*). Docker Compose puede usar env_file: .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Compartidas (products-service e inventory-service)
# -----------------------------------------------------------------------------

# Secreto para firmar/validar JWT (mín. 256 bits para HS256). Debe coincidir en ambos servicios.
JWT_SECRET=default-secret-key-min-256-bits-for-hs256-please-change-in-production

# Límite de peticiones por minuto por IP (opcional; por defecto 100).
APP_RATE_LIMIT_MAX_REQUESTS_PER_MINUTE=100

# Duración del token JWT en segundos (solo products-service; por defecto 3600).
APP_JWT_EXPIRATION_SECONDS=3600

# -----------------------------------------------------------------------------
# products-service
# -----------------------------------------------------------------------------

# Puerto HTTP (por defecto 8080)
PRODUCTS_SERVER_PORT=8080

# Base de datos PostgreSQL
PRODUCTS_SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/products_db
PRODUCTS_SPRING_DATASOURCE_USERNAME=products
PRODUCTS_SPRING_DATASOURCE_PASSWORD=products

# API Key que deben enviar los clientes internos (ej. inventory-service) en X-API-Key.
# Debe coincidir con INVENTORY_APP_PRODUCTS_SERVICE_API_KEY.
PRODUCTS_INTERNAL_API_KEY=internal-api-key-change-in-prod

# -----------------------------------------------------------------------------
# inventory-service
# -----------------------------------------------------------------------------

# Puerto HTTP (por defecto 8081)
INVENTORY_SERVER_PORT=8081

# Base de datos PostgreSQL
INVENTORY_SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/inventory_db
INVENTORY_SPRING_DATASOURCE_USERNAME=inventory
INVENTORY_SPRING_DATASOURCE_PASSWORD=inventory

# URL del products-service (en Docker: http://products-service:8080)
INVENTORY_APP_PRODUCTS_SERVICE_URL=http://localhost:8080
# API Key para llamar a products-service (mismo valor que PRODUCTS_INTERNAL_API_KEY)
INVENTORY_APP_PRODUCTS_SERVICE_API_KEY=internal-api-key-change-in-prod
# Timeout en ms para llamadas HTTP (por defecto 3000)
INVENTORY_APP_PRODUCTS_SERVICE_TIMEOUT_MS=3000

# -----------------------------------------------------------------------------
# Perfil y Flyway (opcional)
# -----------------------------------------------------------------------------
# SPRING_PROFILES_ACTIVE=default
# SPRING_FLYWAY_ENABLED=true

# -----------------------------------------------------------------------------
# SonarQube (solo para ./mvnw sonar:sonar; no son usadas por la app)
# -----------------------------------------------------------------------------
SONAR_TOKEN=default-token-for-sonar-local
SONAR_HOST_URL=http://localhost:9000
# Solo SonarCloud: descomenta y rellena
# SONAR_ORGANIZATION=
# SONAR_PROJECT_KEY=
# =============================================================================
